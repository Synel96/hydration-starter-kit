{
  "extends": ["stylelint-config-standard", "stylelint-config-tailwindcss"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "apply",
          "theme",
          "custom-variant",
          "layer",
          "config",
          "import"
        ]
      }
    ],
    "import-notation": "string"
  }
}
