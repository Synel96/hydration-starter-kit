{
  "extends": ["stylelint-config-standard", "stylelint-config-tailwindcss"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "apply",
          "theme",
          "custom-variant",
          "layer",
          "config",
          "import",
          "screen"
        ]
      }
    ],
    "import-notation": "string",
    "property-no-unknown": [
      true,
      {
        "ignoreProperties": ["composes"]
      }
    ],
    "no-invalid-double-slash-comments": null
  }
}
